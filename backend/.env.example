# Environment variables for AnywhereDoor Server
# Copy this file to .env and customize for your setup

# Database Configuration
# For SQLite (local development):
DATABASE_URL=sqlite:///./any_where_door.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/anywhere_door

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Configuration
API_TITLE=AnywhereDoor Server
API_VERSION=1.0.0
API_DESCRIPTION=File sync and management server for AnywhereDoor agent

# File Storage Configuration
FILE_STORAGE_DIR=./storage/files
MAX_FILE_SIZE_MB=500

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True
LOG_LEVEL=info

# CORS Configuration (for production, specify exact origins)
ALLOWED_ORIGINS=*
